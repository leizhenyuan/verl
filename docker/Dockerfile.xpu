FROM intel/deep-learning-essentials:2025.1.3-0-devel-ubuntu24.04 AS vllm-base

RUN rm -f /etc/apt/sources.list.d/intel-graphics.list

# 安装系统依赖
RUN apt clean && apt-get update -y && \
    apt-get install -y software-properties-common && \
    add-apt-repository ppa:deadsnakes/ppa && \
    apt-get install -y python3.10 python3.10-distutils && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3.10 && \
    apt-get install -y --no-install-recommends --fix-missing \
    curl \
    ffmpeg \
    git \
    libsndfile1 \
    libsm6 \
    libxext6 \
    libgl1 \
    lsb-release \
    numactl \
    python3.10-dev \
    wget \
    vim \
    htop \
    tree \
    tmux \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 设置 Python 版本
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

# 设置工作目录
WORKDIR /workspace

# 🔧 使用 Git Clone 替代 COPY
ARG VLLM_REPO=https://github.com/vllm-project/vllm.git
ARG VLLM_BRANCH=main
ARG VLLM_COMMIT=

RUN git clone ${VLLM_REPO} vllm && \
    cd vllm && \
    if [ -n "${VLLM_COMMIT}" ]; then \
        echo "Checking out specific commit: ${VLLM_COMMIT}"; \
        git checkout ${VLLM_COMMIT}; \
    elif [ "${VLLM_BRANCH}" != "main" ]; then \
        echo "Checking out branch: ${VLLM_BRANCH}"; \
        git checkout ${VLLM_BRANCH}; \
    fi && \
    git submodule update --init --recursive && \
    echo "Successfully cloned vLLM repository"

# 切换到 vLLM 目录
WORKDIR /workspace/vllm

# 安装 Python 依赖
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
    -r requirements/xpu.txt && \
    echo "XPU requirements installed successfully"

# 安装通用依赖
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -f requirements/common.txt ]; then \
        pip install --no-cache-dir -r requirements/common.txt; \
    fi

# 设置环境变量
ENV LD_LIBRARY_PATH="$LD_LIBRARY_PATH:/usr/local/lib/"
ENV VLLM_TARGET_DEVICE=xpu
ENV VLLM_WORKER_MULTIPROC_METHOD=spawn

# 🔧 简化的仓库检查（可选）
ARG GIT_REPO_CHECK=0
RUN if [ "$GIT_REPO_CHECK" != 0 ] && [ -f tools/check_repo.sh ]; then \
        echo "Running repository check..."; \
        bash tools/check_repo.sh; \
    fi

# 从源码安装 vLLM
RUN --mount=type=cache,target=/root/.cache/pip \
    echo "Installing vLLM from source..." && \
    VLLM_TARGET_DEVICE=xpu python3 setup.py install && \
    echo "vLLM installation completed successfully"

# 安装开发工具
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install ipython jupyter-console rich && \
    echo "Development tools installed successfully"

# 🔧 安装 verl 
WORKDIR /workspace
ARG VERL_REPO=https://github.com/volcengine/verl.git
ARG VERL_BRANCH=main
ARG VERL_COMMIT=

RUN git clone ${VERL_REPO} verl && \
    cd verl && \
    if [ -n "${VERL_COMMIT}" ]; then \
        echo "Checking out specific verl commit: ${VERL_COMMIT}"; \
        git checkout ${VERL_COMMIT}; \
    elif [ "${VERL_BRANCH}" != "main" ]; then \
        echo "Checking out verl branch: ${VERL_BRANCH}"; \
        git checkout ${VERL_BRANCH}; \
    fi && \
    git submodule update --init --recursive && \
    echo "Successfully cloned verl repository"

# 安装 verl 依赖
WORKDIR /workspace/verl
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir -r requirements.txt && \
    echo "verl requirements installed successfully"

# 从源码安装 verl
RUN --mount=type=cache,target=/root/.cache/pip \
    echo "Installing verl from source..." && \
    pip install -e . && \
    echo "verl installation completed successfully"

# 🔧 修复字符编码问题，创建欢迎脚本
RUN echo '#!/bin/bash' > /workspace/welcome.sh && \
    echo 'clear' >> /workspace/welcome.sh && \
    echo 'echo "🚀 Welcome to vLLM + verl XPU Development Environment"' >> /workspace/welcome.sh && \
    echo 'echo "======================================================="' >> /workspace/welcome.sh && \
    echo 'echo "📍 vLLM directory: /workspace/vllm"' >> /workspace/welcome.sh && \
    echo 'echo "📍 verl directory: /workspace/verl"' >> /workspace/welcome.sh && \
    echo 'echo "🔧 Python version: $(python --version)"' >> /workspace/welcome.sh && \
    echo 'echo "🎯 vLLM target device: $VLLM_TARGET_DEVICE"' >> /workspace/welcome.sh && \
    echo 'echo "📦 vLLM commit: $(cd /workspace/vllm && git rev-parse --short HEAD 2>/dev/null || echo unknown)"' >> /workspace/welcome.sh && \
    echo 'echo "� verl commit: $(cd /workspace/verl && git rev-parse --short HEAD 2>/dev/null || echo unknown)"' >> /workspace/welcome.sh && \
    echo 'echo "�📂 vLLM branch: $(cd /workspace/vllm && git branch --show-current 2>/dev/null || echo unknown)"' >> /workspace/welcome.sh && \
    echo 'echo "📂 verl branch: $(cd /workspace/verl && git branch --show-current 2>/dev/null || echo unknown)"' >> /workspace/welcome.sh && \
    echo 'echo ""' >> /workspace/welcome.sh && \
    echo 'echo "💡 Useful commands:"' >> /workspace/welcome.sh && \
    echo 'echo "  python -c \"from vllm import LLM; print(\\\"vLLM imported successfully\\\")\"  # Test vLLM"' >> /workspace/welcome.sh && \
    echo 'echo "  python -c \"import verl; print(\\\"verl imported successfully\\\")\"           # Test verl"' >> /workspace/welcome.sh && \
    echo 'echo "  ipython                                                                    # IPython console"' >> /workspace/welcome.sh && \
    echo 'echo "  htop                                                                       # System monitor"' >> /workspace/welcome.sh && \
    echo 'echo "  tree /workspace                                                           # Show directory structure"' >> /workspace/welcome.sh && \
    echo 'echo "  cd /workspace/vllm && git log --oneline -5                               # vLLM recent commits"' >> /workspace/welcome.sh && \
    echo 'echo "  cd /workspace/verl && git log --oneline -5                               # verl recent commits"' >> /workspace/welcome.sh && \
    echo 'echo ""' >> /workspace/welcome.sh && \
    echo 'echo "🔍 Quick test:"' >> /workspace/welcome.sh && \
    echo 'echo "  python -c \"import torch; print(f\\\"PyTorch version: {torch.__version__}\\\")\""' >> /workspace/welcome.sh && \
    echo 'echo ""' >> /workspace/welcome.sh && \
    chmod +x /workspace/welcome.sh

# 设置启动时的欢迎信息
RUN echo 'if [ -t 1 ] && [ -f /workspace/welcome.sh ]; then /workspace/welcome.sh; fi' >> /root/.bashrc

# 设置工作目录
WORKDIR /workspace

# 使用交互式 bash 作为默认命令
CMD ["/bin/bash"]